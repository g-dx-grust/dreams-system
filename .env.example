# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ログインUI
NEXT_PUBLIC_ENABLE_PASSWORD_LOGIN=true

# Server Action / Route Handler 専用（ブラウザに露出させない）
SUPABASE_SERVICE_ROLE_KEY=

# アプリ
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Lark OpenAPI（Server Action / Route Handler専用）
LARK_OPEN_API_BASE_URL=https://open.larksuite.com
LARK_AUTH_BASE_URL=https://accounts.larksuite.com
LARK_APP_ID=
LARK_APP_SECRET=
LARK_LOGIN_SCOPE=contact:user.base:readonly contact:user.email:readonly
LARK_CALENDAR_ID=
LARK_SYNC_SECRET=
LARK_EVENT_VERIFY_TOKEN=
LARK_DAILY_REPORT_CHAT_ID=
LARK_DAILY_REPORT_RECEIVE_ID_TYPE=chat_id
KANRI_CALENDAR_API_SECRET=

# 帳票出力（Supabase Storage バケット名）
STORAGE_BUCKET_TEMPLATES=templates
STORAGE_BUCKET_DOCUMENTS=documents

# AIマッピング候補作成（Server Action専用）
OPENAI_API_KEY=
OPENAI_AI_MAPPING_MODEL=gpt-5.4-mini
