# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Auth Custom OAuth/OIDC Provider（Lark）
NEXT_PUBLIC_SUPABASE_LARK_PROVIDER=custom:lark
NEXT_PUBLIC_ENABLE_PASSWORD_LOGIN=true

# Server Action / Route Handler 専用（ブラウザに露出させない）
SUPABASE_SERVICE_ROLE_KEY=

# アプリ
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# 帳票出力（Supabase Storage バケット名）
STORAGE_BUCKET_TEMPLATES=templates
STORAGE_BUCKET_DOCUMENTS=documents

# AIマッピング候補作成（Server Action専用）
OPENAI_API_KEY=
OPENAI_AI_MAPPING_MODEL=gpt-5.4-mini
