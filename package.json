{
  "name": "kanri-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "typegen": "next typegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "docs:screenshots": "playwright test tests/e2e/manual-screenshots.spec.ts",
    "docs:screenshots:install": "playwright install chromium",
    "docs:pdf": "node scripts/export-user-manual-pdf.mjs",
    "templates:import": "node scripts/import-templates.mjs",
    "templates:upload-originals": "node scripts/upload-template-originals.mjs",
    "mapping:toyohashi-check": "node scripts/setup-toyohashi-mapping-check.mjs",
    "db:types": "supabase gen types typescript --linked > src/types/database.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "^3.6.0",
    "docxtemplater": "^3.50.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "latest",
    "next": "^15.0.0",
    "openai": "^6.35.0",
    "pizzip": "^3.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "tailwind-merge": "latest",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "supabase": "latest",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  }
}
